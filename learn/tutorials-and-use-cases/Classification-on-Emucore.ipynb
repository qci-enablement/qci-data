    "def WSR_MSE(y_true, y_pred):\n",
    "    count = 0\n",
    "    success = 0\n",
    "    \n",
    "    for estimate_winner, target in zip(y_pred, y_true):\n",
    "        if (estimate_winner == target).all():\n",
    "            success += 1\n",
    "        count += 1\n",
    "    \n",
    "    # Handle case where count might be zero\n",
    "    if count == 0:\n",
    "        return 0.0  # or any other appropriate handling\n",
    "    \n",
    "    wsr = success / count\n",
    "    return wsr\n"
   ]
